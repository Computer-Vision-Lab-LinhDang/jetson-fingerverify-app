# Copy to /etc/default/mdgt-litestream and fill in your values.
#
# Cloudflare R2 example (recommended — free egress, S3-compatible):
#   LITESTREAM_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
#   LITESTREAM_REGION=auto
#
# AWS S3 example:
#   LITESTREAM_ENDPOINT=
#   LITESTREAM_REGION=ap-southeast-1
#
# Backblaze B2 example:
#   LITESTREAM_ENDPOINT=https://s3.us-west-002.backblazeb2.com
#   LITESTREAM_REGION=us-west-002

LITESTREAM_BUCKET=mdgt-edge-backups
LITESTREAM_ENDPOINT=
LITESTREAM_REGION=auto
LITESTREAM_ACCESS_KEY_ID=REPLACE_ME
LITESTREAM_SECRET_ACCESS_KEY=REPLACE_ME

# Unique per-device — matches config/default.yaml -> device.id
LITESTREAM_DEVICE_ID=edge-001
